# Postal — example environment configuration.
# Copy to `.env` for local dev: `cp .env.example .env`
# The real `.env` is gitignored and must never contain committed secrets.

# --- Server ---
# Network address the API server binds to.
POSTAL_HTTP_ADDR=:8080
# Environment name: development | staging | production. Controls log format/verbosity.
POSTAL_ENV=development
# Log level: debug | info | warn | error.
POSTAL_LOG_LEVEL=debug
# Graceful-shutdown grace period.
POSTAL_SHUTDOWN_TIMEOUT=15s
# Per-request handler timeout.
POSTAL_REQUEST_TIMEOUT=30s

# --- Docker host ports (compose reads these for port mapping) ---
# Override if your machine already runs Postgres/Redis on the standard ports.
POSTAL_PG_HOST_PORT=5432
POSTAL_REDIS_HOST_PORT=6379

# --- PostgreSQL ---
# Full DSN used by pgx. Host/port must match POSTAL_PG_HOST_PORT above.
POSTAL_DATABASE_URL=postgres://postal:postal@localhost:5432/postal?sslmode=disable

# --- Redis ---
# Redis address (asynq broker + rate-limit counters + cache).
# Host/port must match POSTAL_REDIS_HOST_PORT above.
POSTAL_REDIS_ADDR=localhost:6379
POSTAL_REDIS_PASSWORD=
POSTAL_REDIS_DB=0

# --- Crypto (Phase 1+) ---
# 32-byte master key for AES-256-GCM envelope encryption, base64-encoded.
# Generate with: openssl rand -base64 32
# REQUIRED before token-vault features; left blank here so scaffolding runs without it.
POSTAL_MASTER_KEY=
