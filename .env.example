# Postal — example environment configuration.
# Copy to `.env` for local dev: `cp .env.example .env`
# The real `.env` is gitignored and must never contain committed secrets.

# --- Server ---
# Network address the API server binds to.
POSTAL_HTTP_ADDR=:8080
# Environment name: development | staging | production. Controls log format/verbosity.
POSTAL_ENV=development
# Log level: debug | info | warn | error.
POSTAL_LOG_LEVEL=debug
# Graceful-shutdown grace period.
POSTAL_SHUTDOWN_TIMEOUT=15s
# Per-request handler timeout.
POSTAL_REQUEST_TIMEOUT=30s

# --- Docker host ports (compose reads these for port mapping) ---
# Override if your machine already runs Postgres/Redis on the standard ports.
POSTAL_PG_HOST_PORT=5432
POSTAL_REDIS_HOST_PORT=6379

# --- PostgreSQL ---
# Full DSN used by pgx. Host/port must match POSTAL_PG_HOST_PORT above.
POSTAL_DATABASE_URL=postgres://postal:postal@localhost:5432/postal?sslmode=disable

# --- Redis ---
# Redis address (asynq broker + rate-limit counters + cache).
# Host/port must match POSTAL_REDIS_HOST_PORT above.
POSTAL_REDIS_ADDR=localhost:6379
POSTAL_REDIS_PASSWORD=
POSTAL_REDIS_DB=0

# --- Crypto (Phase 1+) ---
# 32-byte master key for AES-256-GCM envelope encryption, base64-encoded.
# Generate with: openssl rand -base64 32
# REQUIRED before token-vault features; left blank here so scaffolding runs without it.
POSTAL_MASTER_KEY=

# --- Auth (Phase 2) ---
# Secret for signing HS256 JWT access tokens. REQUIRED to enable auth endpoints.
# Generate with: openssl rand -base64 48
POSTAL_JWT_SECRET=
# Access token lifetime and refresh token sliding/absolute lifetimes.
POSTAL_ACCESS_TOKEN_TTL=15m
POSTAL_REFRESH_TOKEN_TTL=720h
POSTAL_REFRESH_TOKEN_MAX_TTL=2160h
# Auth cookie scoping. Set COOKIE_SECURE=false only for local http development.
POSTAL_COOKIE_DOMAIN=
POSTAL_COOKIE_SECURE=true

# --- Transactional email (Resend) ---
# Postal sends account-verification and password-reset email exclusively via
# Resend (resend.com). REQUIRED in production (the server refuses to start auth
# without it); in development, leaving these blank uses the console mailer that
# logs tokens. The From address's domain must be verified in your Resend account.
POSTAL_RESEND_API_KEY=
POSTAL_MAIL_FROM=Postal <noreply@example.com>
# Public web base used to build the action links inside emails (verify/reset).
POSTAL_APP_BASE_URL=

# --- X / Twitter app (Phase 4) ---
# From the X developer portal. Leave blank to disable the X channel.
# NOTE: X API is pay-per-use as of 2026 — posting is billed per request.
POSTAL_X_CLIENT_ID=
POSTAL_X_CLIENT_SECRET=
# Where the IdP returns the browser. For the web app this is the FRONTEND
# callback page (it completes the exchange against the API):
POSTAL_X_REDIRECT_URI=http://localhost:3000/oauth/callback
# Override the real X hosts to use the local simulator (`postal sim`) for
# dev/e2e. Leave blank in production (defaults to api.x.com / x.com).
POSTAL_X_API_BASE_URL=
POSTAL_X_AUTH_BASE_URL=
# Address `postal sim` listens on (default 127.0.0.1:10090).
POSTAL_X_SIM_ADDR=
# Consumer secret (API Key Secret) for the Account Activity webhook CRC challenge
# + event signatures. Empty = the /api/v1/webhooks/twitter endpoint is disabled.
POSTAL_X_WEBHOOK_SECRET=

# --- Object storage (Phase 7): S3-compatible. Prod = Cloudflare R2, dev = MinIO ---
# R2 (prod): ENDPOINT=<account>.r2.cloudflarestorage.com, REGION=auto, USE_SSL=true,
#   ACCESS_KEY/SECRET_KEY from the R2 dashboard.
# MinIO (local docker-compose): the values below. Leave ENDPOINT blank to disable media.
POSTAL_STORAGE_ENDPOINT=localhost:9000
POSTAL_STORAGE_ACCESS_KEY=postal
POSTAL_STORAGE_SECRET_KEY=postalminio
POSTAL_STORAGE_BUCKET=postal-media
POSTAL_STORAGE_REGION=
POSTAL_STORAGE_USE_SSL=false
# Per-file and per-workspace size limits (bytes).
POSTAL_STORAGE_MAX_UPLOAD_BYTES=536870912
POSTAL_STORAGE_MAX_WORKSPACE_BYTES=2147483648

# --- Security hardening (Phase 9) ---
# CORS allowlist: comma-separated exact origins permitted to call the API from a
# browser (credentialed). Empty disables CORS (same-origin / native clients).
# "*" is intentionally unsupported with credentialed requests.
POSTAL_CORS_ALLOWED_ORIGINS=

# --- Billing (Phase 13): wallet credit economics; X is the only paid platform ---
# Tiered by content: plain / media / link posts (X bills URL posts at ~$0.20).
POSTAL_BILLING_CREDITS_PER_USD_CENT=1
POSTAL_BILLING_PUBLISH_COST_TWITTER=10
POSTAL_BILLING_PUBLISH_COST_TWITTER_MEDIA=15
POSTAL_BILLING_PUBLISH_COST_TWITTER_URL=25
POSTAL_BILLING_MIN_TOPUP_CREDITS=500
POSTAL_BILLING_RETURN_URL=http://localhost:3000/wallet
POSTAL_STRIPE_SECRET_KEY=
POSTAL_STRIPE_WEBHOOK_SECRET=
POSTAL_PAYSTACK_SECRET_KEY=
POSTAL_PAYSTACK_NGN_PER_USD=1600

# --- Integrations: OGShortener (workspace keys are stored encrypted) ---
# Override the live ogshortener.site host for tests/dev; blank = real service.
POSTAL_OGSHORTENER_API_BASE=

# --- Instagram (Meta app; Phase 14). Blank client id = disabled. ---
# Production needs Meta App Review (instagram_basic, instagram_content_publish);
# only Business/Creator accounts linked to a Facebook Page can publish.
POSTAL_IG_CLIENT_ID=
POSTAL_IG_CLIENT_SECRET=
POSTAL_IG_REDIRECT_URI=http://localhost:3000/oauth/callback
# Override real Meta hosts with the simulator (postal sim) in dev; blank = real.
POSTAL_IG_API_BASE_URL=
POSTAL_IG_AUTH_BASE_URL=
POSTAL_IG_SIM_ADDR=

# --- TikTok (Phase 14). Blank client key = disabled. ---
# Unaudited TikTok API clients can only post PRIVATE videos; their audit
# (2-4 weeks) lifts the restriction.
POSTAL_TIKTOK_CLIENT_KEY=
POSTAL_TIKTOK_CLIENT_SECRET=
POSTAL_TIKTOK_REDIRECT_URI=http://localhost:3000/oauth/callback
POSTAL_TIKTOK_API_BASE_URL=
POSTAL_TIKTOK_AUTH_BASE_URL=
POSTAL_TIKTOK_SIM_ADDR=

# --- OAuth redirect allowlist (Phase 15.2). Comma-separated. A connect request
#     may only override the adapter default with a URI listed here (anti-open-
#     redirect). Include the web callback page and any native deep links. ---
POSTAL_OAUTH_ALLOWED_REDIRECTS=
